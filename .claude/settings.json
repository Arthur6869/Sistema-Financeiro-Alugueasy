{
  "permissions": {
    "allow": [
      "mcp__claude_ai_Supabase__list_migrations",
      "Bash(npm run:*)"
    ]
  },
  "mcpServers": {
    "alugueasy": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        ".claude/start-alugueasy-mcp.ps1"
      ]
    },
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref",
        "rlkmljeatapayiroggrp",
        "--read-only"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "PREENCHER_PAT_DO_SUPABASE_DASHBOARD"
      }
    }
  }
}

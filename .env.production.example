# ── Supabase ──────────────────────────────────────────────────────────────
# Obtido em: supabase.com > projeto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://rlkmljeatapayiroggrp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=PREENCHER_ANON_KEY

# ── Supabase Server-side (não expor no cliente) ───────────────────────────
# Obtido em: supabase.com > projeto > Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=PREENCHER_SERVICE_ROLE_KEY

# ── Amenitiz ──────────────────────────────────────────────────────────────
# Obtido em: Amenitiz Dashboard > Configurações > Integrações > API
AMENITIZ_ACCESS_TOKEN=PREENCHER_ACCESS_TOKEN
AMENITIZ_BASE_URL=https://api.amenitiz.io/vendor_api/v1
AMENITIZ_HOTEL_UUID=PREENCHER_HOTEL_UUID
AMENITIZ_BATCAVE_ID=PREENCHER_BATCAVE_ID

# ── Segurança interna MCP → API ───────────────────────────────────────────
# Gerar com: openssl rand -hex 32
# Usar o MESMO valor no servidor MCP e aqui
ALUGUEASY_INTERNAL_API_KEY=PREENCHER_CHAVE_32_BYTES_HEX

# ── MCP Server (apenas para deploy do mcp-server, não necessário no Vercel) ─
ALUGUEASY_BASE_URL=https://SEU-DOMINIO-VERCEL.vercel.app
MCP_PORT=3001
